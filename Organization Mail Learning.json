    {
      "parameters": {
        "jsCode": "// Todos los items vienen en el array\nconst rows = $input.all().map(item => item.json);\n\n// Agrupar por combinación mail + categoria\nconst grupos = {};\n\nfor (const row of rows) {\n  const clave = `${row.remitente}|||${row.categoria}`;\n  \n  if (!grupos[clave]) {\n    grupos[clave] = { \n      mail: row.remitente, \n      categoria: row.categoria, \n      cantidad: 0,\n      registros: []\n    };\n  }\n  \n  grupos[clave].cantidad++;\n  grupos[clave].registros.push(row);\n}\n\n// Filtrar combinaciones con más de 4 registros\n// y quedarse solo con el registro más viejo\nconst resultado = Object.values(grupos)\n  .filter(g => g.cantidad > 4)\n  .map(g => {\n    const masViejo = g.registros.sort(\n      (a, b) => +new Date(a.updated) - +new Date(b.updated)\n    )[0];\n\n    return {\n      json: {\n        mail: g.remitente,\n        categoria: g.categoria,\n        cantidad: g.cantidad,\n        registro_mas_viejo: masViejo\n      }\n    };\n  });\n\nreturn resultado;"
      },
