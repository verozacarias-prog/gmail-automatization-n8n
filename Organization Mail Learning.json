    {
      "parameters": {
        "jsCode": "const CATEGORY_TO_LABEL = {\n  'RUIDO_COMERCIAL':     'Label_8608903593625801920',\n  'EVENTO_DE_PAGO':      'Label_5520207168492791595',\n  'IA_Y_EMPRENDIMIENTO': 'Label_1116150865929736285',\n  'TRABAJO_REMOTO':      'Label_6767717741231986689',\n  'AMBIGUO':             'Label_6138867044884961130',\n  'INVERSIONES':         'Label_5875726024538814156',\n  'SALUD/NATURAL':       'Label_6929204943850250196',\n\n};\n\nconst LABEL_TO_CATEGORY = Object.fromEntries(\n  Object.entries(CATEGORY_TO_LABEL).map(([cat, label]) => [label, cat])\n);\n\nconst ALL_MANAGED_IA_LABELS = Object.values(CATEGORY_TO_LABEL);\n\nreturn $input.all()\n  .filter(item => {\n    const currentLabels = (item.json.labels || []).map(l => l.id);\n    return currentLabels.some(id => ALL_MANAGED_IA_LABELS.includes(id));\n  })\n  .map(item => {\n  \n  const currentLabels = (item.json.labels || []).map(l => l.id);\n\n  const oldLabelId = CATEGORY_TO_LABEL[item.json.categoria?.toUpperCase()];\n  const newLabelId = currentLabels.find(id => ALL_MANAGED_IA_LABELS.includes(id));\n  const newCategoria = LABEL_TO_CATEGORY[newLabelId];\n    \n  return {\n    json: {\n      row_number: item.json.row_number,\n      messageID: item.json.messageID,\n      newCategoria,\n      oldLabelId,\n      newLabelId,\n      needsUpdate: newLabelId !== oldLabelId\n    }\n  };\n});"
      },
