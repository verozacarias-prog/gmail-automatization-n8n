    {
      "parameters": {
        "jsCode": "const historicalData = (() => {\n  try { return $('Get History Memorial').all(); } \n  catch (e) { return []; }\n})();\n\nreturn $('When Executed by Another Workflow').all().map(item => {\n  const fromEmail = item.json.from;\n  const categoria = item.json.categoria?.toUpperCase();\n\n  const matches = historicalData.filter(h =>\n    h.json &&\n    Object.keys(h.json).length > 0 &&\n    h.json.remitente === fromEmail &&\n    h.json.categoria?.toUpperCase() === categoria\n  );\n\n  return {\n    json: {\n      id:          item.json.id,\n      from:        fromEmail,\n      output:      item.json.output,\n      historyRows: matches.map(h => ({\n        row_number: h.json.row_number,\n        updated:    h.json.updated\n      })),\n      historyCount: matches.length\n    }\n  };\n});"
      },
