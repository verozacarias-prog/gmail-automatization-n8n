    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst LIMIT = 4;\n\nconsole.log('Items recibidos:', items.length);\nitems.forEach((item, i) => {\n  console.log(`Item ${i}:`, JSON.stringify(item.json).substring(0, 200));\n});\n// Contador local, vive dentro de esta ejecución\nconst batchCounter = {};\n\nreturn items.map(item => {\n  const from = item.json.from;\n  const categoria = item.json.output?.categoria?.toUpperCase();\n  const key = `${from}__${categoria}`;\n\n  const existingCount = item.json.historyCount;\n  const writtenThisBatch = batchCounter[key] || 0;\n  const totalCount = existingCount + writtenThisBatch;\n\n  if (totalCount < LIMIT) {\n    batchCounter[key] = writtenThisBatch + 1;\n    return { json: { action: 'APPEND', id: item.json.id, from, output: item.json.output } };\n  }\n\n  const sorted = (item.json.historyRows || [])\n    .sort((a, b) => new Date(a.updated).getTime() - new Date(b.updated).getTime());\n\n  return { json: {\n    action: 'UPDATE',\n    rowId: sorted[0].row_number,\n    id: item.json.id,\n    from,\n    output: item.json.output\n  }};\n});"
      },
